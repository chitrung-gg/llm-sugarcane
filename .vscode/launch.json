    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Debug Sugarcane Genome Agent",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/agent",
            "jinja": true,
            "envFile": "${workspaceFolder}/agent/.env",
        },
